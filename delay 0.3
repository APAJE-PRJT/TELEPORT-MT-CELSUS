local function waitForRespawn()

local char = player.Character
if char then
char:BreakJoints()
end

player.CharacterAdded:Wait()

local newChar = player.Character
repeat task.wait() until newChar:FindFirstChild("HumanoidRootPart")

task.wait(2)

end

-- AUTO TELEPORT
TeleportTab:CreateToggle({
Name = "AUTO TELEPORT",
CurrentValue = false,
Callback = function(Value)

autoTP = Value

if autoTP then

task.spawn(function()

repeat

jumpTeleport(unpack(BC))
task.wait(delayTP)

for _,v in ipairs(CP) do
if not autoTP then break end
jumpTeleport(v[1],v[2],v[3])
task.wait(delayTP)
end

jumpTeleport(unpack(SUMMIT))

if autoReset then
waitForRespawn()
end

until not autoTP or not autoLoop

autoTP = false

end)

end

end
})

