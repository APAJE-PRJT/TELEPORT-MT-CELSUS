-- fungsi lompat + teleport
local function jumpTeleport(x,y,z)

local char = player.Character
if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") then

Rayfield:Notify({
Title = "Teleport",
Content = "Teleport ke "..math.floor(x)..","..math.floor(y)..","..math.floor(z),
Duration = 3,
Image = 97392696311902
})

-- teleport dulu
char.HumanoidRootPart.CFrame = CFrame.new(x,y,z)

task.wait(0.15)

-- baru lompat
char.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)

end
end

